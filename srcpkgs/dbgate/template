# Template file for 'dbgate'
pkgname=dbgate
version=7.2.1
revision=1
archs="x86_64"
wrksrc="dbgate-${version}"
hostmakedepends="libarchive"
short_desc="Smart database manager"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="MIT"
homepage="https://dbgate.org/"
distfiles="https://github.com/dbgate/dbgate/releases/download/v${version}/dbgate-${version}-linux_amd64.deb"
checksum=a0e0b83ec6eb5cea479e283bddbf1a37f1b3b1a37c16ed271c4afb711bf0ef6d
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio gtk+3"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/dbgate-${version}-linux_amd64.deb \
        -C "${wrksrc}" --include='data.tar*'
    bsdtar -xf "${wrksrc}"/data.tar.* -C "${wrksrc}"
    rm "${wrksrc}"/data.tar.*
}

do_install() {
    vcopy "usr/*" usr
    vmkdir opt/dbgate
    vcopy "opt/DbGate/*" opt/dbgate
    vmkdir usr/bin
    ln -sf /opt/dbgate/dbgate ${DESTDIR}/usr/bin/dbgate

    rm -f ${DESTDIR}/usr/share/applications/dbgate.desktop
    vmkdir usr/share/applications
    vinstall ${FILESDIR}/dbgate.desktop 644 usr/share/applications

    if [ -f opt/DbGate/LICENSE.electron.txt ]; then
        vlicense opt/DbGate/LICENSE.electron.txt
    elif [ -f usr/share/doc/dbgate/copyright ]; then
        vlicense usr/share/doc/dbgate/copyright
    else
        vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
    fi
}