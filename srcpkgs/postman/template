# Template file for 'postman'
pkgname=postman
version=12.18.3
revision=1
archs="x86_64"
wrksrc="postman-${version}"
hostmakedepends="libarchive"
short_desc="API development environment"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="custom:Postman"
homepage="https://www.postman.com/"
distfiles="https://dl.pstmn.io/download/latest/linux64>postman-linux-x64.tar.gz"
checksum=f075f76107711c7a7b4557440919c68933b14da9f438d7e6f67e8e744d2998a4
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio gtk+3"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/postman-linux-x64.tar.gz \
        --strip-components 1 -C "${wrksrc}"
}

do_install() {
    vmkdir opt/postman
    vcopy "*" opt/postman
    vcopy ".[!.]*" opt/postman 2>/dev/null || true

    vmkdir usr/bin
    ln -sf /opt/postman/Postman ${DESTDIR}/usr/bin/postman

    local icon_found=""
    for dir in "app/resources/icons" "icons" "resources/icons"; do
        for name in postman Postman icon; do
            local icon_path="${DESTDIR}/opt/postman/${dir}/${name}.png"
            if [ -f "$icon_path" ]; then
                vmkdir usr/share/icons/hicolor/256x256/apps
                vinstall "$icon_path" 644 usr/share/icons/hicolor/256x256/apps postman.png
                vmkdir usr/share/pixmaps
                vinstall "$icon_path" 644 usr/share/pixmaps postman.png
                icon_found=1
                break 2
            fi
        done
    done
    if [ -z "$icon_found" ]; then
        vmkdir usr/share/icons/hicolor/256x256/apps
        vinstall ${FILESDIR}/postman.png 644 usr/share/icons/hicolor/256x256/apps postman.png
        vmkdir usr/share/pixmaps
        vinstall ${FILESDIR}/postman.png 644 usr/share/pixmaps postman.png
    fi

    rm -f ${DESTDIR}/usr/share/applications/postman.desktop
    vmkdir usr/share/applications
    vinstall ${FILESDIR}/postman.desktop 644 usr/share/applications

    if [ -f LICENSE ]; then
        vlicense LICENSE
    elif [ -f LICENSE.md ]; then
        vlicense LICENSE.md
    else
        vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
    fi
}