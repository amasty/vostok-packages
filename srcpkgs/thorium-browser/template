# Template file for 'thorium-browser'
pkgname=thorium-browser
version=138.0.7204.303
revision=1
archs="x86_64"
wrksrc="thorium-browser-${version}"
hostmakedepends="libarchive"
short_desc="Thorium Browser - fast, privacy-focused Chromium fork"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="BSD-3-Clause"
homepage="https://thorium.rocks/"
distfiles="https://github.com/Alex313031/thorium/releases/download/M${version}/thorium-browser_${version}_AVX.deb"
checksum=9bfad87fd5119720a1bc47af3b3e3efcbd92910032aa949d97bdc5191e2edb60
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio gtk+3 libXScrnSaver libXtst nss liberation-fonts-ttf xdg-utils"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/thorium-browser_${version}_AVX.deb \
        -C "${wrksrc}" --include='data.tar*'
    bsdtar -xf "${wrksrc}"/data.tar.* -C "${wrksrc}"
    rm "${wrksrc}"/data.tar.*
}

do_install() {
    vcopy "usr/*" usr
    vcopy "opt/*" opt

    # Удаляем cron
    rm -f ${DESTDIR}/etc/cron.daily/thorium-browser

    # Симлинки: thorium и thorium-browser → /opt/thorium/thorium-browser
    vmkdir usr/bin
    rm -f ${DESTDIR}/usr/bin/thorium ${DESTDIR}/usr/bin/thorium-browser
    ln -sf /opt/thorium/thorium-browser ${DESTDIR}/usr/bin/thorium-browser
    ln -sf /opt/thorium/thorium-browser ${DESTDIR}/usr/bin/thorium

    # Удаляем лишние ярлыки (оставляем только наш)
    rm -f ${DESTDIR}/usr/share/applications/thorium-browser.desktop
    rm -f ${DESTDIR}/usr/share/applications/org.chromium.Thorium.desktop
    rm -f ${DESTDIR}/usr/share/applications/thorium-shell.desktop

    # Ставим свой desktop
    vmkdir usr/share/applications
    vinstall ${FILESDIR}/thorium.desktop 644 usr/share/applications

    # Иконки
    for size in 16 24 32 48 64 128 256; do
        if [ -f "opt/chromium.org/thorium/product_logo_${size}.png" ]; then
            vmkdir "usr/share/icons/hicolor/${size}x${size}/apps"
            vinstall "opt/chromium.org/thorium/product_logo_${size}.png" 644 \
                "usr/share/icons/hicolor/${size}x${size}/apps" thorium.png
        fi
    done
    vmkdir usr/share/pixmaps
    vinstall "opt/chromium.org/thorium/product_logo_256.png" 644 usr/share/pixmaps thorium.png

    # Лицензия
    if [ -f "opt/chromium.org/thorium/LICENSE" ]; then
        vlicense opt/chromium.org/thorium/LICENSE
    elif [ -f "usr/share/doc/thorium-browser/copyright" ]; then
        vlicense usr/share/doc/thorium-browser/copyright
    else
        vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
    fi
}