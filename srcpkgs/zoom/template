# Template file for 'zoom'
pkgname=zoom
version=7.0.5
revision=1
archs="x86_64"
wrksrc="zoom-${version}"
short_desc="Video Conferencing and Web Conferencing Service"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="custom:Zoom"
homepage="https://zoom.us/"
distfiles="https://cdn.zoom.us/prod/${version}.3034/zoom_x86_64.pkg.tar.xz"
checksum=787248918d6a442ef3dfe93a00ca20db095bcbc5a0ba9cb8f00e4eed42918955
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio gtk+3"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/zoom_x86_64.pkg.tar.xz -C "${wrksrc}"
}

do_install() {
    vcopy "usr/*" usr

    vmkdir opt/zoom
    for f in opt/zoom/*; do
        if [ -f "$f" ]; then
            vinstall "$f" 755 opt/zoom
        elif [ -d "$f" ]; then
            vcopy "$f" "opt/zoom/$(basename "$f")"
        fi
    done

    chmod 755 ${DESTDIR}/opt/zoom/zoom 2>/dev/null || true
    chmod 755 ${DESTDIR}/opt/zoom/ZoomLauncher 2>/dev/null || true

    rm -f ${DESTDIR}/.INSTALL ${DESTDIR}/.PKGINFO

    if [ -f usr/share/pixmaps/Zoom.png ]; then
        mv ${DESTDIR}/usr/share/pixmaps/Zoom.png ${DESTDIR}/usr/share/pixmaps/zoom.png
    fi
    if [ -f usr/share/applications/Zoom.desktop ]; then
        sed -i 's|^Icon=.*|Icon=zoom|' ${DESTDIR}/usr/share/applications/Zoom.desktop
        sed -i 's|^Exec=.*|Exec=zoom %U|' ${DESTDIR}/usr/share/applications/Zoom.desktop
        mv ${DESTDIR}/usr/share/applications/Zoom.desktop ${DESTDIR}/usr/share/applications/zoom.desktop
    fi

    vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
}