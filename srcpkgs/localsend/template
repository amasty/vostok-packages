# Template file for 'localsend'
pkgname=localsend
version=1.17.0
revision=1
archs="x86_64"
wrksrc="localsend-${version}"
hostmakedepends="libarchive"
short_desc="Open source cross-platform alternative to AirDrop"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="MIT"
homepage="https://localsend.org/"
distfiles="https://github.com/localsend/localsend/releases/download/v${version}/LocalSend-${version}-linux-x86-64.deb"
checksum=b0244b2c3eacb2a81d61b2662534d6036ab37ace10d6782da36b630c222fa04c
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio gtk+3"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/LocalSend-${version}-linux-x86-64.deb \
        -C "${wrksrc}" --include='data.tar*'
    bsdtar -xf "${wrksrc}"/data.tar.* -C "${wrksrc}"
    rm "${wrksrc}"/data.tar.*
}

do_install() {
    vmkdir opt/localsend
    vcopy "usr/share/localsend_app/*" opt/localsend

    vmkdir usr/bin
    ln -sf /opt/localsend/localsend_app ${DESTDIR}/usr/bin/localsend

    for size in 128 256; do
        if [ -f "usr/share/icons/hicolor/${size}x${size}/apps/localsend_app.png" ]; then
            vmkdir "usr/share/icons/hicolor/${size}x${size}/apps"
            vinstall "usr/share/icons/hicolor/${size}x${size}/apps/localsend_app.png" 644 \
                "usr/share/icons/hicolor/${size}x${size}/apps" localsend.png
        fi
    done
    vmkdir usr/share/pixmaps
    local pixmap_src="usr/share/icons/hicolor/256x256/apps/localsend_app.png"
    [ ! -f "$pixmap_src" ] && pixmap_src="usr/share/icons/hicolor/128x128/apps/localsend_app.png"
    vinstall "$pixmap_src" 644 usr/share/pixmaps localsend.png

    rm -f ${DESTDIR}/usr/share/applications/localsend_app.desktop
    vmkdir usr/share/applications
    vinstall ${FILESDIR}/localsend.desktop 644 usr/share/applications

    if [ -f "usr/share/doc/localsend_app/copyright" ]; then
        vlicense usr/share/doc/localsend_app/copyright
    else
        vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
    fi
}